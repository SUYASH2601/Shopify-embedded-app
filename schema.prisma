generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Shop {
  id          String @id @default(cuid())
  shop        String @unique
  accessToken String
}


model Order {
  id        Int    @id @default(autoincrement())
  shop      String
  orderId   String
  totalPrice String
}